{
  "uid": "system-health",
  "title": "System Health",
  "tags": ["monitoring", "system"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "uid": "nI9ZjC5Dz" },
        "query": "SHOW TAG VALUES FROM \"cpu\" WITH KEY = \"host\"",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT 100 - last(\"usage_idle\") FROM \"cpu\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY \"host\"",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"used_percent\") FROM \"mem\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY \"host\"",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    },
    {
      "id": 3,
      "title": "Disk Usage",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"used_percent\") FROM \"disk\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY \"host\"",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Temperature",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 75 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"temp\") FROM \"temp\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY \"host\"",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"usage_user\") FROM \"cpu\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host user"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"usage_system\") FROM \"cpu\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "B",
          "alias": "$tag_host system"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"usage_iowait\") FROM \"cpu\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "C",
          "alias": "$tag_host iowait"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*percent.*" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"used\") FROM \"mem\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host used"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"cached\") FROM \"mem\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "B",
          "alias": "$tag_host cached"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"available\") FROM \"mem\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "C",
          "alias": "$tag_host available"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"used_percent\") FROM \"mem\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "D",
          "alias": "$tag_host percent"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"used\") FROM \"disk\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host used"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"free\") FROM \"disk\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "B",
          "alias": "$tag_host free"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT last(\"used_percent\") FROM \"disk\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY \"host\"",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    },
    {
      "id": 9,
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT non_negative_derivative(last(\"bytes_recv\"), 1s) FROM \"net\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host rx"
        },
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT non_negative_derivative(last(\"bytes_sent\"), 1s) FROM \"net\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "B",
          "alias": "$tag_host tx"
        }
      ]
    },
    {
      "id": 10,
      "title": "CPU Temperature Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "datasource": { "uid": "nI9ZjC5Dz" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 75 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "uid": "nI9ZjC5Dz" },
          "query": "SELECT mean(\"temp\") FROM \"temp\" WHERE (\"host\" =~ /^$host$/) AND $timeFilter GROUP BY time($__interval), \"host\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "alias": "$tag_host"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
