{
  "dashboard": {
    "title": "Water Pressure Monitor",
    "uid": "water-pressure-monitor",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "location",
          "type": "query",
          "datasource": {
            "uid": "nI9ZjC5Dz",
            "type": "influxdb"
          },
          "query": "SHOW TAG VALUES FROM pressure WITH KEY = location",
          "includeAll": true,
          "allValue": "",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "multi": false,
          "refresh": 2,
          "sort": 1
        },
        {
          "name": "sensor",
          "type": "query",
          "datasource": {
            "uid": "nI9ZjC5Dz",
            "type": "influxdb"
          },
          "query": "SHOW TAG VALUES FROM pressure WITH KEY = sensor WHERE location =~ /^$location$/",
          "includeAll": true,
          "allValue": "",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "multi": true,
          "refresh": 2,
          "sort": 1
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Current Pressure by Sensor",
        "type": "stat",
        "gridPos": { "h": 6, "w": 18, "x": 0, "y": 0 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"value\") FROM \"pressure\" WHERE location =~ /^$location$/ AND sensor =~ /^$sensor$/ AND $timeFilter GROUP BY sensor",
            "alias": "$tag_sensor",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "psi",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "green", "value": 30 },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 80 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 7,
        "title": "Pump Status",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"power_w\") FROM \"power\" WHERE (circuit = 'new_pump' OR circuit = 'old_pump') AND $timeFilter GROUP BY circuit",
            "alias": "$tag_circuit",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "watt",
            "decimals": 0,
            "mappings": [
              {
                "type": "range",
                "options": {
                  "from": 0,
                  "to": 10,
                  "result": { "text": "OFF", "color": "text", "index": 0 }
                }
              },
              {
                "type": "range",
                "options": {
                  "from": 10,
                  "to": 999999,
                  "result": { "index": 1 }
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "text", "value": null },
                { "color": "orange", "value": 10 },
                { "color": "red", "value": 2000 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "vertical",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center"
        }
      },
      {
        "id": 2,
        "title": "Pressure Timeline",
        "type": "timeseries",
        "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT mean(\"value\") FROM \"pressure\" WHERE location =~ /^$location$/ AND sensor =~ /^$sensor$/ AND $timeFilter GROUP BY time($__interval), sensor fill(null)",
            "alias": "$tag_sensor",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          },
          {
            "query": "SELECT mean(\"power_w\") FROM \"power\" WHERE (circuit = 'new_pump' OR circuit = 'old_pump') AND $timeFilter GROUP BY time($__interval), circuit fill(null)",
            "alias": "$tag_circuit",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "psi",
            "decimals": 1,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": true,
              "axisPlacement": "auto"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            },
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byRegexp", "options": "new_pump|old_pump" },
              "properties": [
                { "id": "unit", "value": "watt" },
                { "id": "custom.axisPlacement", "value": "right" },
                { "id": "custom.axisLabel", "value": "Pump Power (W)" },
                { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } },
                { "id": "custom.lineWidth", "value": 1 },
                { "id": "custom.fillOpacity", "value": 5 },
                { "id": "decimals", "value": 0 }
              ]
            }
          ]
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["lastNotNull", "min", "max", "mean"]
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 3,
        "title": "Pressure by Location (24h)",
        "type": "table",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 18 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"value\") AS \"Current PSI\", min(\"value\") AS \"Min (24h)\", max(\"value\") AS \"Max (24h)\", mean(\"value\") AS \"Avg (24h)\" FROM \"pressure\" WHERE time > now() - 24h AND location =~ /^$location$/ AND sensor =~ /^$sensor$/ GROUP BY sensor, location",
            "rawQuery": true,
            "resultFormat": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 1,
            "custom": {
              "align": "auto"
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "time" },
              "properties": [
                { "id": "custom.hidden", "value": true }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Current PSI" },
              "properties": [
                { "id": "unit", "value": "psi" },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "red", "value": null },
                      { "color": "yellow", "value": 20 },
                      { "color": "green", "value": 30 },
                      { "color": "yellow", "value": 70 },
                      { "color": "red", "value": 80 }
                    ]
                  }
                },
                { "id": "custom.displayMode", "value": "color-background" }
              ]
            },
            {
              "matcher": { "id": "byRegexp", "options": "Min|Max|Avg" },
              "properties": [
                { "id": "unit", "value": "psi" }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [
            { "displayName": "sensor", "desc": false }
          ]
        }
      },
      {
        "id": 4,
        "title": "Status Overview",
        "type": "stat",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT count(\"value\") FROM \"pressure\" WHERE status_ok = true AND time > now() - 5m GROUP BY sensor",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto"
        }
      },
      {
        "id": 5,
        "title": "System Stability",
        "type": "stat",
        "gridPos": { "h": 4, "w": 12, "x": 0, "y": 26 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"stable\") FROM \"pressure\" WHERE location =~ /^$location$/ AND $timeFilter GROUP BY location",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "UNSTABLE", "color": "orange", "index": 0 }, "1": { "text": "STABLE", "color": "green", "index": 1 } } },
              { "type": "value", "options": { "false": { "text": "UNSTABLE", "color": "orange", "index": 0 }, "true": { "text": "STABLE", "color": "green", "index": 1 } } }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "orange", "value": null },
                { "color": "green", "value": 1 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "horizontal",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center"
        }
      },
      {
        "id": 6,
        "title": "Stability Timeline",
        "type": "timeseries",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 26 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"stable\") FROM \"pressure\" WHERE location =~ /^$location$/ AND $timeFilter GROUP BY time($__interval), location fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "decimals": 0,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 30,
              "showPoints": "never",
              "spanNulls": true,
              "drawStyle": "line",
              "stacking": { "mode": "none" }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "orange", "value": null },
                { "color": "green", "value": 1 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        }
      }
    ],
    "schemaVersion": 36,
    "version": 0
  },
  "overwrite": true
}
