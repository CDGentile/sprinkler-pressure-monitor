{
  "dashboard": {
    "title": "Water Pressure Monitor",
    "uid": "water-pressure-monitor",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "location",
          "type": "query",
          "datasource": {
            "uid": "nI9ZjC5Dz",
            "type": "influxdb"
          },
          "query": "SHOW TAG VALUES FROM pressure WITH KEY = location",
          "includeAll": true,
          "allValue": "",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "multi": false,
          "refresh": 2,
          "sort": 1
        },
        {
          "name": "sensor",
          "type": "query",
          "datasource": {
            "uid": "nI9ZjC5Dz",
            "type": "influxdb"
          },
          "query": "SHOW TAG VALUES FROM pressure WITH KEY = sensor WHERE location =~ /^$location$/",
          "includeAll": true,
          "allValue": "",
          "current": {
            "text": "All",
            "value": "$__all"
          },
          "multi": true,
          "refresh": 2,
          "sort": 1
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Current Pressure by Sensor",
        "type": "stat",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"value\") FROM \"pressure\" WHERE location =~ /^$location$/ AND sensor =~ /^$sensor$/ AND $timeFilter GROUP BY sensor",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "psi",
            "decimals": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "green", "value": 30 },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 80 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "Pressure Timeline",
        "type": "timeseries",
        "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT mean(\"value\") FROM \"pressure\" WHERE location =~ /^$location$/ AND sensor =~ /^$sensor$/ AND $timeFilter GROUP BY time($__interval), sensor fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "psi",
            "decimals": 1,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "spanNulls": true
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            },
            "color": {
              "mode": "palette-classic"
            }
          },
          "overrides": []
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": ["lastNotNull", "min", "max", "mean"]
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 3,
        "title": "Pressure by Location (24h)",
        "type": "table",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 18 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT last(\"value\") AS \"Current PSI\", min(\"value\") AS \"Min (24h)\", max(\"value\") AS \"Max (24h)\", mean(\"value\") AS \"Avg (24h)\" FROM \"pressure\" WHERE time > now() - 24h AND location =~ /^$location$/ AND sensor =~ /^$sensor$/ GROUP BY sensor, location",
            "rawQuery": true,
            "resultFormat": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 1,
            "custom": {
              "align": "auto"
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "time" },
              "properties": [
                { "id": "custom.hidden", "value": true }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Current PSI" },
              "properties": [
                { "id": "unit", "value": "psi" },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "red", "value": null },
                      { "color": "yellow", "value": 20 },
                      { "color": "green", "value": 30 },
                      { "color": "yellow", "value": 70 },
                      { "color": "red", "value": 80 }
                    ]
                  }
                },
                { "id": "custom.displayMode", "value": "color-background" }
              ]
            },
            {
              "matcher": { "id": "byRegexp", "options": "Min|Max|Avg" },
              "properties": [
                { "id": "unit", "value": "psi" }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [
            { "displayName": "sensor", "desc": false }
          ]
        }
      },
      {
        "id": 4,
        "title": "Status Overview",
        "type": "stat",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
        "datasource": {
          "uid": "nI9ZjC5Dz",
          "type": "influxdb"
        },
        "targets": [
          {
            "query": "SELECT count(\"value\") FROM \"pressure\" WHERE status_ok = true AND time > now() - 5m GROUP BY sensor",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "red", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            },
            "color": {
              "mode": "thresholds"
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto"
        }
      }
    ],
    "schemaVersion": 36,
    "version": 0
  },
  "overwrite": true
}
