# Sprinkler1 Environment Configuration
# Device: 192.168.0.100 (main_site)
#
# Copy to /home/cdgentile/sprinkler-pressure-monitor/.env on the device

INFLUXDB_URL=http://192.168.0.18:8086
INFLUXDB_DATABASE=sensors
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=

MQTT_HOST=192.168.0.18
MQTT_PORT=1883
MQTT_TOPIC=home/sensors/pressure
MQTT_USERNAME=
MQTT_PASSWORD=

SITE_NAME=main_site
CLIENT_ID=sprinkler1

CONSOLE_OUTPUT=false
MQTT_OUTPUT=false
INFLUXDB_OUTPUT=true
VERBOSE=false

LOG_LEVEL=INFO
LOG_FILE=/var/log/sprinkler-monitor/monitor.log
