# Environment Configuration for Sprinkler Pressure Monitor
#
# Copy this file to .env and customize for your device.
# The .env file is gitignored - never commit secrets!

# InfluxDB connection (primary data storage)
INFLUXDB_URL=http://192.168.0.18:8086
INFLUXDB_DATABASE=sensors

# Optional InfluxDB auth (leave empty if not using authentication)
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=

# MQTT connection (optional - for Home Assistant integration)
MQTT_HOST=192.168.0.18
MQTT_PORT=1883
MQTT_TOPIC=home/sensors/pressure

# Optional MQTT auth
MQTT_USERNAME=
MQTT_PASSWORD=

# Device identity
# SITE_NAME should match a site in config.yaml (main_site or aux_site)
SITE_NAME=main_site
CLIENT_ID=sprinkler1

# Output selection (true/false)
CONSOLE_OUTPUT=false
MQTT_OUTPUT=false
INFLUXDB_OUTPUT=true
VERBOSE=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=
